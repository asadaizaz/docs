{
  "openapi": "3.1.0",
  "info": {
    "title": "Offload API",
    "version": "0.1.0",
    "description": "Implementation-aligned reference for the current public Offload API."
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "<your-offload-api-host>"
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Public client routes authenticate with the x-api-key header."
      }
    },
    "schemas": {
      "Counterparty": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "address",
          "name"
        ],
        "properties": {
          "address": {
            "type": "string",
            "minLength": 1,
            "description": "Email address or other contact address. The implemented workflow uses this as the email recipient."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "company": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "customData": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Optional string-to-string facts that are injected into prompt context."
          }
        }
      },
      "SenderPersona": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "tone": {
            "type": "string"
          }
        }
      },
      "CaseGoal": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objective"
        ],
        "properties": {
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "knowledge": {
            "description": "Optional additional context. The API accepts either a string or an object.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        }
      },
      "CreateCaseRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "channel",
          "goal",
          "counterparty",
          "senderPersona"
        ],
        "properties": {
          "channel": {
            "type": "string",
            "enum": [
              "EMAIL",
              "SMS"
            ],
            "description": "Request validation accepts EMAIL and SMS. The implemented workflow is email-based."
          },
          "clientReferenceId": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "maxAttempts": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum automated follow-up attempts after the initial outreach. Defaults to 3."
          },
          "followUpDelayHours": {
            "type": "integer",
            "minimum": 1,
            "description": "Delay between automated follow-up attempts in hours. Defaults to 72."
          },
          "goal": {
            "$ref": "#/components/schemas/CaseGoal"
          },
          "counterparty": {
            "$ref": "#/components/schemas/Counterparty"
          },
          "senderPersona": {
            "$ref": "#/components/schemas/SenderPersona"
          },
          "resultSchema": {
            "type": "object",
            "additionalProperties": true,
            "description": "Expected to be JSON Schema-shaped, but the API only validates that it is an object."
          },
          "clientWebhookUrl": {
            "type": "string",
            "format": "uri"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "example": {
          "clientReferenceId": "vendor_2048",
          "channel": "EMAIL",
          "maxAttempts": 3,
          "followUpDelayHours": 72,
          "goal": {
            "objective": "Collect a signed W-9 from the vendor",
            "knowledge": {
              "vendorName": "Northstar Supplies",
              "reason": "AP onboarding"
            }
          },
          "counterparty": {
            "address": "ap@northstar.example",
            "name": "Maya Chen",
            "company": "Northstar Supplies",
            "timezone": "America/Los_Angeles",
            "customData": {
              "vendorId": "vendor_2048"
            }
          },
          "senderPersona": {
            "name": "Avery",
            "role": "Accounts Payable",
            "company": "Example Corp",
            "tone": "friendly, concise"
          },
          "resultSchema": {
            "type": "object",
            "properties": {
              "signedW9Received": {
                "type": "boolean"
              }
            },
            "required": [
              "signedW9Received"
            ]
          },
          "clientWebhookUrl": "https://your-app.example/webhooks/offload",
          "metadata": {
            "vendorId": "vendor_2048"
          }
        }
      },
      "CreateCaseResponseData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "caseId"
        ],
        "properties": {
          "caseId": {
            "type": "string",
            "description": "UUID assigned to the new case."
          }
        }
      },
      "CreateCaseResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ok",
          "data"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/CreateCaseResponseData"
          }
        }
      },
      "CaseInputRequestResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "question",
          "status",
          "requestedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "RESOLVED",
              "NONE",
              "PENDING"
            ]
          },
          "requestedAt": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      },
      "CaseAttachment": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "attachmentId",
          "size",
          "messageId",
          "inboxId",
          "receivedAt"
        ],
        "properties": {
          "attachmentId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "messageId": {
            "type": "string"
          },
          "inboxId": {
            "type": "string",
            "description": "Underlying AgentMail inbox identifier stored on the case."
          },
          "receivedAt": {
            "type": "integer"
          }
        }
      },
      "GetCaseResponseData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "caseId",
          "status",
          "createdAt",
          "updatedAt",
          "attemptCount",
          "maxAttempts",
          "channel",
          "counterparty",
          "attachments",
          "goal",
          "senderPersona",
          "inputRequest"
        ],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "clientReferenceId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "CREATED",
              "RUNNING",
              "COMPLETED",
              "FAILED",
              "INPUT_NEEDED"
            ]
          },
          "createdAt": {
            "type": "integer"
          },
          "updatedAt": {
            "type": "integer"
          },
          "nextActionAt": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Next scheduled follow-up timestamp. Unscheduled cases currently return the sentinel 253402300799999."
          },
          "attemptCount": {
            "type": "integer",
            "description": "Outbound messages sent so far."
          },
          "maxAttempts": {
            "type": "integer",
            "description": "Maximum automated follow-up attempts after the initial outreach."
          },
          "channel": {
            "type": "string",
            "enum": [
              "EMAIL",
              "SMS"
            ]
          },
          "counterparty": {
            "$ref": "#/components/schemas/Counterparty"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CaseAttachment"
            },
            "description": "Inbound attachments tracked on the case."
          },
          "resultStatus": {
            "type": "string",
            "description": "Open workflow outcome string. Known values include goal_achieved, max_retries, failed_rejected, BOUNCED, COMPLAINED, and REJECTED."
          },
          "result": {
            "type": "object",
            "additionalProperties": true
          },
          "goal": {
            "$ref": "#/components/schemas/CaseGoal"
          },
          "resultSchema": {
            "type": "object",
            "additionalProperties": true
          },
          "senderPersona": {
            "$ref": "#/components/schemas/SenderPersona"
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputRequest": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/CaseInputRequestResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "conversationThread": {
            "type": [
              "string",
              "null"
            ],
            "description": "Formatted plain-text transcript. Only included when includeTranscript=true."
          }
        }
      },
      "GetCaseResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ok",
          "data"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/GetCaseResponseData"
          }
        }
      },
      "GetCaseAttachmentResponseData": {
        "allOf": [
          {
            "$ref": "#/components/schemas/CaseAttachment"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "downloadUrl",
              "expiresAt"
            ],
            "properties": {
              "downloadUrl": {
                "type": "string",
                "format": "uri"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        ]
      },
      "GetCaseAttachmentApiResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ok",
          "data"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/GetCaseAttachmentResponseData"
          }
        }
      },
      "ProvideCaseInputRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "inputRequestId",
          "providedContext"
        ],
        "properties": {
          "inputRequestId": {
            "type": "string",
            "minLength": 1
          },
          "providedContext": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "ProvideCaseInputResponseData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "caseId",
          "inputRequestId",
          "accepted"
        ],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "inputRequestId": {
            "type": "string"
          },
          "accepted": {
            "const": true
          }
        }
      },
      "ProvideCaseInputResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ok",
          "data"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/ProvideCaseInputResponseData"
          }
        }
      },
      "ClientWebhookEventData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "caseId",
          "status",
          "channel",
          "attemptCount",
          "attachments"
        ],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "clientReferenceId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "CREATED",
              "RUNNING",
              "COMPLETED",
              "FAILED",
              "INPUT_NEEDED"
            ]
          },
          "channel": {
            "type": "string",
            "enum": [
              "EMAIL",
              "SMS"
            ]
          },
          "attemptCount": {
            "type": "integer"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CaseAttachment"
            }
          },
          "result": {
            "type": "object",
            "additionalProperties": true
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "resultStatus": {
            "type": "string"
          },
          "failureReason": {
            "type": [
              "string",
              "null"
            ]
          },
          "inputRequest": {
            "type": [
              "string",
              "null"
            ]
          },
          "inputRequestId": {
            "type": [
              "string",
              "null"
            ]
          },
          "inputRequestStatus": {
            "type": [
              "string",
              "null"
            ]
          },
          "inputRequestedAt": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      },
      "ClientWebhookEvent": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "event_type",
          "timestamp",
          "data"
        ],
        "properties": {
          "event_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string",
            "enum": [
              "case.completed",
              "case.failed",
              "case.input_needed"
            ]
          },
          "timestamp": {
            "type": "integer"
          },
          "data": {
            "$ref": "#/components/schemas/ClientWebhookEventData"
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ok",
          "error"
        ],
        "properties": {
          "ok": {
            "const": false
          },
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/cases": {
      "post": {
        "summary": "Create case",
        "description": "Creates a case, stores it with status CREATED, and queues async processing.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCaseRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Case created and queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Inactive API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Usage limit reached or gateway throttling",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error while creating the case",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases/{id}": {
      "get": {
        "summary": "Get case",
        "description": "Returns the current public case state. If includeTranscript=true, Offload fetches and formats the live AgentMail thread.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeTranscript",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Transcript is only included when this value is the literal string true."
          }
        ],
        "responses": {
          "200": {
            "description": "Current case state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing case ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Inactive API key or case belongs to another user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Case not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected upstream or platform error. Transcript-fetch failures may not use the standard JSON envelope."
          }
        }
      }
    },
    "/cases/{id}/attachments/{attachmentId}": {
      "get": {
        "summary": "Get case attachment",
        "description": "Returns a fresh download URL for an attachment already stored on the case.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attachmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fresh attachment download URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCaseAttachmentApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing case ID or attachment ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Inactive API key or case belongs to another user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Case or attachment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Attachment lookup failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases/{id}/input": {
      "post": {
        "summary": "Provide case input",
        "description": "Queues human input for a case paused in INPUT_NEEDED.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProvideCaseInputRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Input accepted and queued for async processing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvideCaseInputResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing case ID or invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Inactive API key or case belongs to another user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Case not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Case is not waiting for input, the request is no longer pending, or the request ID is stale",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failed to queue the provided input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
