{
  "openapi": "3.1.0",
  "info": {
    "title": "Offload API",
    "description": "API for asynchronous human coordination over email.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://2dr03s75sl.execute-api.us-west-2.amazonaws.com"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/cases": {
      "post": {
        "summary": "Create case",
        "description": "Creates a new asynchronous coordination case and enqueues the workflow.",
        "requestBody": {
          "description": "Case creation payload",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCaseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Case created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Monthly usage limit reached",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases/{id}": {
      "get": {
        "summary": "Get case",
        "description": "Returns the current status and public state for a case owned by the authenticated client.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Case ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeTranscript",
            "in": "query",
            "description": "When true, fetches the full case email transcript from AgentMail and includes it as conversationThread.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Case response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Case not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases/{id}/attachments/{attachmentId}": {
      "get": {
        "summary": "Get case attachment",
        "description": "Returns a fresh expiring download URL for an attachment previously received on the case.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Case ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attachmentId",
            "in": "path",
            "description": "Attachment ID from the case attachments array",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fresh attachment download link",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCaseAttachmentApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Case or attachment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cases/{id}/input": {
      "post": {
        "summary": "Provide case input",
        "description": "Resumes a case that is waiting for human input.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Case ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Human input payload",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProvideCaseInputRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Input accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvideCaseInputResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Case not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Case cannot accept input in its current state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "caseEvent": {
      "post": {
        "description": "Webhook sent to the clientWebhookUrl configured on the case.",
        "requestBody": {
          "description": "Webhook event payload",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientWebhookEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Return any 2xx status to indicate successful receipt"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Counterparty": {
        "type": "object",
        "required": ["address", "name"],
        "properties": {
          "address": {
            "description": "Email address or phone number to contact.",
            "type": "string"
          },
          "name": {
            "description": "Human-friendly name of the counterparty.",
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "customData": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "SenderPersona": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "tone": {
            "type": "string"
          }
        }
      },
      "CaseGoal": {
        "type": "object",
        "required": ["objective"],
        "properties": {
          "objective": {
            "type": "string"
          },
          "knowledge": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        }
      },
      "CreateCaseRequest": {
        "type": "object",
        "required": ["channel", "goal", "counterparty", "senderPersona"],
        "properties": {
          "channel": {
            "type": "string",
            "enum": ["EMAIL", "SMS"]
          },
          "clientReferenceId": {
            "type": "string"
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "maxAttempts": {
            "type": "integer",
            "minimum": 1
          },
          "followUpDelayHours": {
            "type": "integer",
            "minimum": 1
          },
          "goal": {
            "$ref": "#/components/schemas/CaseGoal"
          },
          "counterparty": {
            "$ref": "#/components/schemas/Counterparty"
          },
          "senderPersona": {
            "$ref": "#/components/schemas/SenderPersona"
          },
          "resultSchema": {
            "type": "object",
            "additionalProperties": true
          },
          "clientWebhookUrl": {
            "type": "string",
            "format": "uri"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "CreateCaseResponseData": {
        "type": "object",
        "required": ["caseId"],
        "properties": {
          "caseId": {
            "type": "string"
          }
        }
      },
      "CreateCaseResponse": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/CreateCaseResponseData"
          }
        }
      },
      "CaseInputRequestResponse": {
        "type": "object",
        "required": ["id", "question", "status", "requestedAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["RESOLVED", "NONE", "PENDING"]
          },
          "requestedAt": {
            "type": ["integer", "null"]
          }
        }
      },
      "CaseAttachment": {
        "type": "object",
        "required": ["attachmentId", "size", "messageId", "inboxId", "receivedAt"],
        "properties": {
          "attachmentId": {
            "type": "string",
            "description": "Stable attachment ID returned by AgentMail."
          },
          "name": {
            "type": "string",
            "description": "Original filename when available."
          },
          "size": {
            "type": "integer",
            "description": "Attachment size in bytes."
          },
          "type": {
            "type": "string",
            "description": "MIME content type when available."
          },
          "messageId": {
            "type": "string",
            "description": "AgentMail message ID that carried the attachment."
          },
          "inboxId": {
            "type": "string",
            "description": "AgentMail inbox used to fetch a fresh download URL."
          },
          "receivedAt": {
            "type": "integer",
            "description": "Unix timestamp in milliseconds for when Offload saw the attachment."
          }
        }
      },
      "GetCaseResponseData": {
        "type": "object",
        "required": [
          "caseId",
          "status",
          "createdAt",
          "updatedAt",
          "attemptCount",
          "maxAttempts",
          "channel",
          "counterparty",
          "attachments",
          "goal",
          "senderPersona",
          "inputRequest"
        ],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "clientReferenceId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["CREATED", "RUNNING", "COMPLETED", "FAILED", "INPUT_NEEDED"]
          },
          "createdAt": {
            "type": "integer"
          },
          "updatedAt": {
            "type": "integer"
          },
          "nextActionAt": {
            "type": ["integer", "null"]
          },
          "attemptCount": {
            "type": "integer"
          },
          "maxAttempts": {
            "type": "integer"
          },
          "channel": {
            "type": "string",
            "enum": ["EMAIL", "SMS"]
          },
          "counterparty": {
            "$ref": "#/components/schemas/Counterparty"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CaseAttachment"
            },
            "description": "Inbound attachments seen on the case. Use the attachment endpoint to mint fresh download URLs."
          },
          "resultStatus": {
            "type": "string"
          },
          "result": {
            "type": "object",
            "additionalProperties": true
          },
          "goal": {
            "$ref": "#/components/schemas/CaseGoal"
          },
          "resultSchema": {
            "type": "object",
            "additionalProperties": true
          },
          "senderPersona": {
            "$ref": "#/components/schemas/SenderPersona"
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputRequest": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/CaseInputRequestResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "conversationThread": {
            "type": ["string", "null"],
            "description": "Formatted case email transcript. Only included when includeTranscript=true is requested."
          }
        }
      },
      "GetCaseResponse": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/GetCaseResponseData"
          }
        }
      },
      "GetCaseAttachmentResponseData": {
        "allOf": [
          {
            "$ref": "#/components/schemas/CaseAttachment"
          },
          {
            "type": "object",
            "required": ["downloadUrl", "expiresAt"],
            "properties": {
              "downloadUrl": {
                "type": "string",
                "format": "uri",
                "description": "Fresh expiring AgentMail download URL."
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "description": "When the download URL expires."
              }
            }
          }
        ]
      },
      "GetCaseAttachmentApiResponse": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/GetCaseAttachmentResponseData"
          }
        }
      },
      "ProvideCaseInputRequest": {
        "type": "object",
        "required": ["inputRequestId", "providedContext"],
        "properties": {
          "inputRequestId": {
            "type": "string"
          },
          "providedContext": {
            "type": "string"
          }
        }
      },
      "ProvideCaseInputResponseData": {
        "type": "object",
        "required": ["caseId", "inputRequestId", "accepted"],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "inputRequestId": {
            "type": "string"
          },
          "accepted": {
            "type": "boolean",
            "const": true
          }
        }
      },
      "ProvideCaseInputResponse": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "data": {
            "$ref": "#/components/schemas/ProvideCaseInputResponseData"
          }
        }
      },
      "ClientWebhookEventData": {
        "type": "object",
        "required": ["caseId", "status", "channel", "attemptCount", "attachments"],
        "properties": {
          "caseId": {
            "type": "string"
          },
          "clientReferenceId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["CREATED", "RUNNING", "COMPLETED", "FAILED", "INPUT_NEEDED"]
          },
          "channel": {
            "type": "string",
            "enum": ["EMAIL", "SMS"]
          },
          "attemptCount": {
            "type": "integer"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CaseAttachment"
            },
            "description": "Inbound attachments seen on the case."
          },
          "result": {
            "type": "object",
            "additionalProperties": true
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "resultStatus": {
            "type": "string"
          },
          "failureReason": {
            "type": ["string", "null"]
          },
          "inputRequest": {
            "type": ["string", "null"]
          },
          "inputRequestId": {
            "type": ["string", "null"]
          },
          "inputRequestStatus": {
            "type": ["string", "null"]
          },
          "inputRequestedAt": {
            "type": ["integer", "null"]
          }
        }
      },
      "ClientWebhookEvent": {
        "type": "object",
        "required": ["event_id", "event_type", "timestamp", "data"],
        "properties": {
          "event_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string",
            "enum": ["case.completed", "case.failed", "case.input_needed"]
          },
          "timestamp": {
            "type": "integer"
          },
          "data": {
            "$ref": "#/components/schemas/ClientWebhookEventData"
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["ok", "error"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": false
          },
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  }
}
